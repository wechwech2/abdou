{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@abdou/shared-types": ["packages/shared-types/src/index.ts"],
      "@abdou/shared-config/*": ["packages/shared-config/src/*"],
      "@abdou/shared-utils/*": ["packages/shared-utils/src/*"]
    }
  }
}
