APP_ENV=development
APP_TIMEZONE=Africa/Tunis
SESSION_NAME=ABDOU_ADMIN

ADMIN_PHP_PORT=8080
ADMIN_PHP_BASE_URL=http://127.0.0.1:8080
ADMIN_PHP_TIMEOUT_MS=15000
ADMIN_API_COMPAT_ENABLED=false
PREVIEW_SERVER_PORT=4173

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=abdou
