Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Servir les fichiers existants tels quels
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Fallback vers index.html pour navigation statique
  RewriteRule ^ index.html [L]
</IfModule>
